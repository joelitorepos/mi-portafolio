          </svg>
        </a>
      </li>

    </ul>
  </nav>
</header>

<style>
  header {
    animation: adaptar-nav both;
    animation-timeline: scroll();
    animation-range: 20px 150px;
  }

  @keyframes adaptar-nav {
    from { background-color: #191924; }
    to { background-color: #18233f66; }
  }

  .icon-link {
    display: grid;
    place-items: center;
    opacity: 0.85;
    transition: opacity 0.2s, transform 0.2s;
  }

  .icon-link:hover {
    opacity: 1;
    transform: translateY(-2px);
  }
</style>