---
// Footer.astro
import FooterLink from './FooterLink.astro';

const currentPath = Astro.url.pathname;
---

<footer class="h-[10dvh] bg-[#12122b] border-t border-[#48e3]/20 w-full mt-auto">
  <nav class="h-full">
    <ul class="flex h-full text-xl">
      
      <FooterLink 
        href="/mi-portafolio/" 
        label="Inicio" 
        isActive={currentPath === '/mi-portafolio/' || currentPath === '/mi-portafolio'} 
      />
      
      <FooterLink 
        href="/mi-portafolio/projects" 
        label="Proyectos" 
        isActive={currentPath === '/mi-portafolio/projects'} 
      />
      
      <FooterLink 
        href="/mi-portafolio/about" 
        label="Sobre mí" 
        isActive={currentPath === '/mi-portafolio/about'} 
      />
      
      <FooterLink 
        href="/mi-portafolio/contact" 
        label="Contacto" 
        isActive={currentPath === '/mi-portafolio/contact'} 
      />

    </ul>
  </nav>
</footer>

<style>
  footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Efecto neon más pronunciado al hover */
  footer a:hover span {
    text-shadow: 
      0 0 8px #48e3,
      0 0 16px #48e3,
      0 0 24px #48e3;
  }
</style>