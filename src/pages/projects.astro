---
import Layout from "../Layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Footer from "../components/Footer.astro";
import Tecnology from "../components/Tecnology.astro";
import "../styles/global.css";
import FeaturedProject from "../components/FeaturedProject.astro";
import petClinicPreview from "../images/pet-clinic-preview.png";
import TechChip from "../components/TechChip.astro";
---
<Layout>
    <h2 class="text-center mt-[1rem] text-[2rem]">Proyectos</h2>
    <!-- PROYECTO PRINCIPAL -->
    <div class="p-[1rem]">
        <FeaturedProject
            title="Pet Clinic Manager"
            description="Sistema de gestión para clínicas veterinarias. Permite administrar pacientes, expedientes, imágenes y seguimiento de acciones — todo en una base de datos segura con validaciones estrictas."
            image={petClinicPreview.src}
            imageAlt="Captura de pantalla de Pet Clinic Manager"
            siteUrl="https://pet-clinic-manager.com"
            repoUrl="https://github.com/joelitorepos/pet-clinic-manager"
            domain="pet-clinic-manager.com"
            badge="En producción"
            stack={["React", "TypeScript", "Express.js", "MongoDB", "Mongoose", "Docker"]}
            bullets={[
                { icon: "ti-database",        text: "CRUD completo con múltiples tipos de registro" },
                { icon: "ti-photo",            text: "Almacenamiento de imágenes de pacientes" },
                { icon: "ti-table-export",     text: "Exportación de datos a Excel" },
                { icon: "ti-clipboard-list",   text: "Auditoría de acciones (plan pago)" },
            ]}
            infra={[
                { label: "Frontend — Cloudflare Pages",   sub: "React + TypeScript" },
                { label: "Backend — Oracle Cloud VM",     sub: "Express.js · Docker · Cloudflare Tunnel" },
                { label: "Base de datos — MongoDB Atlas", sub: "M0 · Mongoose ODM" },
                { label: "Dominio propio",                sub: "pet-clinic-manager.com" },
            ]}
        />
    </div>
    <section class="grid grid-cols-[repeat(auto-fill,minmax(32rem,1fr))] gap-[1rem] p-[1rem]">     
        <ProjectCard
        title="Gestor de URLs y grupos de pestañas"
        description="una extension para chrome que permite gestionar urls y grupos de pestañas, una manera de organizar tus pestañas y urls"
        image="/mi-portafolio/images/extension.png"
        alt="extension"
        link="https://chromewebstore.google.com/detail/gestor-de-urls-grupos-de/kcgnaddmfibpmkfghbikkgngbnoapioi"
        >
        <div class="inline-flex w-fit h-fit justify-start gap-[1rem] p-[1rem]">
            <TechChip variant="highlight" size="md">HTML</TechChip>
            <TechChip variant="highlight" size="md">CSS</TechChip>
            <TechChip variant="highlight" size="md">TypeScript</TechChip>
        </div>
        </ProjectCard>
        <ProjectCard
            title="Curso para aprender a crear una API"
            description="un curso donde enseño lo necesario de JavaScript para poder crear una API con node.js y express, donde enseño herramientas configuraciones y conocimientos"
            image="/mi-portafolio/images/PROJECT-CURSO.jpg"
            alt="curso-API"
            link="https://joelitorepos.github.io/curso-para-API/"
        >
        <div class="inline-flex w-fit h-fit justify-start gap-[1rem] p-[1rem]">
            <TechChip variant="highlight" size="md">HTML</TechChip>
            <TechChip variant="highlight" size="md">CSS</TechChip>
        </div>
        </ProjectCard>
        <ProjectCard
            title="Portafolio personal"
            description="portafolio para mostrar proyectos y puedan conocer mejor mis habilidades"
            image="/mi-portafolio/images/PROJECT-PORTFOLIO.jpg"
            alt="portafolio"
            link="https://joelitorepos.github.io/portafolio/"
        >
        <div class="inline-flex w-fit h-fit justify-start gap-[1rem] p-[1rem]">
            <TechChip variant="highlight" size="md">HTML</TechChip>
            <TechChip variant="highlight" size="md">CSS</TechChip>
            <TechChip variant="highlight" size="md">JavaScript</TechChip>
        </div>
        </ProjectCard>
    </section>
    <h2 class="text-center text-[2rem]">Tecnologias</h2>
    <section class="w-full h-fit grid grid-cols-[repeat(auto-fill,minmax(9rem,1fr))] justify-center gap-[1rem] p-[1rem]">
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/html.webp"
                alt="html icon"
            />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/css-icon.webp"
                alt="css icon"
            />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/js.png"
                alt="javascript icon"
        />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/typescript-icon.png"
                alt="typescript icon"
        />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/react-icon.png"
                alt="react icon"
        />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/tailwind-icon.png"
                alt="tailwind icon"
        />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/astro-icon.png"
                alt="astro icon"
        />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/node-icon.png"
                alt="nodejs icon"
        />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/mongodb.png"
                alt="mongodb icon"
        />
        </div>
    </section>
    <h2 class="text-center text-[2rem]">Herramientas</h2>
    <section class="w-full h-fit grid grid-cols-[repeat(auto-fill,minmax(9rem,1fr))] justify-center gap-[1rem] p-[1rem]">
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/linux-icon.png"
                alt="linux icon"
            />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/git.webp"
                alt="git icon"
            />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/github-icon.webp"
                alt="github icon"
        />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/vscode-icon.png"
                alt="visual studio code icon"
        />
        </div>
        <div class="h-[10rem] w-[9rem] m-auto">
            <Tecnology
                image="/mi-portafolio/images/cloudflare.png"
                alt="cloudflare icon"
        />
        </div>
    </section>
    <Footer></Footer>
</Layout>
