---
import Layout from "../Layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";

const contacts = [
    {
        label: "Correo electrónico",
        value: "armandojoel2004@gmail.com",
        description: "Para propuestas formales o cualquier consulta.",
        href: "mailto:armandojoel2004@gmail.com",
        cta: "Enviar correo",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    },
    {
        label: "WhatsApp",
        value: null,
        description: "Para respuestas rápidas o una primera conversación informal.",
        href: "https://wa.me/50239423287",
        cta: "Abrir WhatsApp",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>`,
    },
    {
        label: "GitHub",
        value: "github.com/joelitorepos",
        description: "Repositorios, código fuente y proyectos personales.",
        href: "https://github.com/joelitorepos",
        cta: "Ver perfil",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
    },
];
---

<Layout>
    <Header />

    <main class="flex flex-col justify-center min-h-[80dvh] max-w-[700px] mx-auto px-6 py-12 gap-12">

        <div>
            <p class="text-[#4de] uppercase tracking-widest text-sm mb-3">Contacto</p>
            <h1 class="text-3xl font-semibold text-white mb-4 leading-snug">
                ¿Tienes una oportunidad?<br />Hablemos.
            </h1>
            <p class="text-slate-400 leading-relaxed max-w-prose">
                Estoy buscando mi primer empleo formal como practicante, trainee o semi-junior. Si tienes una oportunidad o simplemente quieres conocer más sobre mi trabajo, escríbeme por cualquiera de estos canales.
            </p>
        </div>

        <div class="flex flex-col gap-4">
            {contacts.map(({ label, value, description, href, cta, icon }) => (
                <div class="flex items-center gap-5 bg-[#161b22] border border-[#21262d] rounded-xl px-5 py-4 hover:border-[#4de3]/40 transition-colors group">
                    <div class="text-[#4de] shrink-0">
                        <Fragment set:html={icon} />
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="text-white font-medium text-sm mb-0.5">{label}</div>
                        {value && <div class="text-slate-400 text-xs font-mono mb-1 truncate">{value}</div>}
                        <div class="text-slate-500 text-xs">{description}</div>
                    </div>
                    <a
                        href={href}
                        target={href.startsWith("mailto") ? "_self" : "_blank"}
                        rel="noopener noreferrer"
                        class="shrink-0 text-xs font-medium px-4 py-2 rounded-lg border border-[#4de3]/40 text-[#4de] hover:bg-[#4de]/10 transition-colors whitespace-nowrap"
                    >
                        {cta}
                    </a>
                </div>
            ))}
        </div>

    </main>

    <Footer />
</Layout>